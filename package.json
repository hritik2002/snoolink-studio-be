{
    "name": "snoolink.studio",
    "version": "1.0.0",
    "description": "Backend service for Snoolink.studio",
    "main": "src/server.ts",
    "type": "module",
    "scripts": {
        "start": "tsx src/server.ts",
        "dev": "tsx watch src/server.ts",
        "build": "echo 'No build step needed - using tsx for runtime'",
        "test": "echo \"Error: no test specified\" && exit 1",
        "migrate:namespaces": "tsx src/scripts/migrate-pinecone-namespaces.ts",
        "migrate:namespaces:dry": "DRY_RUN=true tsx src/scripts/migrate-pinecone-namespaces.ts",
        "migrate:collection-metadata": "tsx src/scripts/run-collection-metadata-migration.ts",
        "migrate:collection-metadata:verify": "tsx src/scripts/verify-collection-metadata-migration.ts",
        "reset:all": "tsx src/scripts/reset-all.ts",
        "reset:all:dry": "RESET_CONFIRM=yes tsx src/scripts/reset-all.ts -- --dry-run"
    },
    "keywords": [
        "snoolink.studio",
        "video",
        "embeddings",
        "vector-search"
    ],
    "author": "hritik.sharma",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.967.0",
        "@aws-sdk/s3-request-presigner": "^3.967.0",
        "@pinecone-database/pinecone": "^6.1.3",
        "@supabase/supabase-js": "^2.56.0",
        "@types/compression": "^1.8.1",
        "axios": "^1.11.0",
        "bullmq": "^5.65.1",
        "cloudinary": "^2.7.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "ioredis": "^5.8.2",
        "multer": "^1.4.5-lts.1",
        "openai": "^6.9.1",
        "ts-node": "*",
        "tsx": "^4.20.6",
        "twelvelabs-js": "*",
        "typescript": "*",
        "uuid": "^13.0.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/multer": "^2.0.0",
        "@types/ws": "^8.18.1",
        "nodemon": "^3.0.1",
        "pg": "^8.21.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
